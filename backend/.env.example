# Copy to backend/.env and fill in real values. Never commit .env.

# Required
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional model override
# MISTRAL_MODEL=mistral-large-latest

# At-rest encryption for integration / MCP credentials in SQLite.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or any long random string — Atlas derives a Fernet key via SHA-256.
ATLAS_SECRET_KEY=change-me-to-a-long-random-secret

# JWT signing secret for user login sessions
ATLAS_JWT_SECRET=change-me-to-another-long-random-secret

# Token required on sensitive localhost APIs (code run, MCP custom connect).
# Leave blank to auto-generate into data/local_auth_token (frontend fetches via GET /api/auth/token).
# ATLAS_LOCAL_AUTH_TOKEN=

# Privacy: keep false so diagrams stay local (frontend already renders locally).
# ATLAS_ALLOW_MERMAID_INK=false

# Optional web / YouTube keys
# TAVILY_API_KEY=your_tavily_api_key_here
# YOUTUBE_API_KEY=your_youtube_api_key_here

# LOG_LEVEL=INFO
